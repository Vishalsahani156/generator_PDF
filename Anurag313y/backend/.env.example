PORT=5001

# MongoDB — will run locally in Docker inside this folder (Anurag313y) when you set it up later
# Until then, use a local MongoDB instance or Atlas URI
MONGO_URI=mongodb://127.0.0.1:27017/invoice_generator

JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173

# Admin bootstrap (optional)
# If ADMIN_BOOTSTRAP=true, the server will create/update an admin user on startup.
ADMIN_BOOTSTRAP=true
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin@123
